{
  "rewrites": [
    {
      "source": "/api/notify-step-activated",
      "destination": "https://dvbetgdzksatcgdfftbs.supabase.co/functions/v1/notify-step-activated"
    },
    {
      "source": "/api/notify-form-review",
      "destination": "https://dvbetgdzksatcgdfftbs.supabase.co/functions/v1/notify-form-review"
    },
    {
      "source": "/api/process-form-decision",
      "destination": "https://dvbetgdzksatcgdfftbs.supabase.co/functions/v1/process-form-decision"
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
